{
  "name": "mejiro-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@4.12.0",
  "volta": {
    "node": "22.14.0",
    "yarn": "4.12.0"
  },
  "scripts": {
    "build": "yarn workspaces foreach -At run build",
    "test": "vitest",
    "bench": "vitest bench",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "dev": "yarn workspace @mejiro/demo dev",
    "fetch-demo-epub": "npx tsx scripts/fetch-demo-epub.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "prepublish": "cp LICENSE packages/mejiro/ && cp LICENSE packages/mejiro-react/ && cp LICENSE packages/mejiro-vue/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.30.0",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
